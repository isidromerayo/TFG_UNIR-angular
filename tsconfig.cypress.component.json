{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "types": ["cypress", "node", "cypress-image-snapshot"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "cypress/component/**/*.cy.ts",
    "cypress/support/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}