{
  "name": "frontend-angular",
  "version": "0.2.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test-headless": "ng test --watch=false --browsers=ChromeHeadless",
    "test-headless-cc": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:component": "cypress run --component",
    "cypress:component:open": "cypress open --component",
    "cypress:coverage": "CYPRESS_COVERAGE=true cypress run --component",
    "cypress:component:coverage": "CYPRESS_COVERAGE=true cypress run --component",
    "cypress:component:coverage:open": "CYPRESS_COVERAGE=true cypress open --component",
    "cypress:e2e:coverage": "CYPRESS_COVERAGE=true cypress run --e2e",
    "security": "./scripts/security-check.sh",
    "security:audit": "pnpm audit",
    "security:outdated": "pnpm outdated",
    "verify": "pnpm run test-headless && pnpm run build && pnpm audit",
    "precommit": "pnpm run verify",
    "lint": "eslint src --ext .ts,.html",
    "lint:fix": "eslint src --ext .ts,.html --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/platform-browser-dynamic": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@sweetalert2/ngx-sweetalert2": "^14.1.2",
    "axios": "^1.15.0",
    "form-data": "^4.0.4",
    "rxjs": "~7.8.0",
    "sweetalert2": "11.26.18",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.9",
    "@angular-eslint/eslint-plugin": "^18.4.3",
    "@angular-eslint/eslint-plugin-template": "^18.4.3",
    "@angular-eslint/schematics": "^18.4.3",
    "@angular-eslint/template-parser": "^18.4.3",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@cypress/angular": "^4.1.0",
    "@cypress/code-coverage": "^3.13.4",
    "@cypress/schematic": "^5.0.0",
    "@cypress/webpack-dev-server": "^5.6.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/jasmine": "~5.1.15",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "ajv": "^8.18.0",
    "cypress": "^15.10.0",
    "eslint": "^8.57.1",
    "istanbul-lib-coverage": "^3.2.2",
    "jasmine-core": "~5.13.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "lcov-result-merger": "^5.0.1",
    "nyc": "^18.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.2",
      "js-yaml": ">=4.1.1",
      "tar": ">=7.5.11",
      "lodash": ">=4.18.0",
      "undici": ">=7.24.0",
      "minimatch": ">=3.1.4",
      "karma>minimatch": "^7.0.0",
      "@isaacs/brace-expansion": ">=5.0.1",
      "serialize-javascript": ">=7.0.3",
      "systeminformation": ">=5.31.0",
      "flatted": ">=3.4.0",
      "rollup": ">=4.59.0",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "express-rate-limit": ">=8.2.2",
      "immutable": ">=5.1.5",
      "socket.io-parser": ">=4.2.6",
      "path-to-regexp": ">=8.4.0",
      "node-forge": ">=1.4.0",
      "picomatch": ">=4.0.4",
      "@angular-devkit/core>ajv": ">=8.18.0",
      "follow-redirects": ">=1.16.0",
      "vite": ">=7.3.2",
      "uuid": ">=14.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb"
    ]
  }
}